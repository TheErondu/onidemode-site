<IfModule mod_rewrite.c>
    RewriteEngine On

    # Prevent direct access to /public/ URL (keeps URLs clean)
    RewriteCond %{THE_REQUEST} \s/+public/ [NC]
    RewriteRule ^public/(.*)$ /$1 [R=301,L,NE]

    # Route all requests through Laravel's public folder
    RewriteCond %{REQUEST_URI} !^/public/
    RewriteRule ^(.*)$ public/$1 [L,QSA]
</IfModule>
